# Backend env for HOST-run tooling (Prisma CLI and `pnpm dev` OUTSIDE Docker).
#
# Docker does NOT use this file — containers read the root `.env` (where the DB host
# is `postgres`, the Compose service name). On the host you connect to Postgres on
# `localhost` instead, which is the only difference.
#
# Recreate the real file before running Prisma commands on the host:
#   cp apps/backend/.env.example apps/backend/.env
#
# Used by: `pnpm db:studio`, `pnpm db:migrate`, `pnpm db:seed`, `pnpm dev` (host).

DATABASE_URL=postgresql://appuser:changeme@localhost:5432/taskmanager
ALLOWED_ORIGINS=http://localhost:5173

# Optional (sensible defaults shown):
# NODE_ENV=development
# PORT=3000
# LOG_LEVEL=info
