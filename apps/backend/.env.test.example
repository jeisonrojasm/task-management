# Backend env for the integration test suite (host).
#
# Recreate the real file before running the tests:
#   cp apps/backend/.env.test.example apps/backend/.env.test
#   pnpm test
#
# The tests run on the host against a SEPARATE database (`taskmanager_test`) on
# localhost, so they never touch your development data. Jest's global setup runs
# `prisma migrate deploy` against this URL and creates the database if it does not
# exist — no manual DB creation needed.

NODE_ENV=test
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/taskmanager_test
ALLOWED_ORIGINS=http://localhost:5173
PORT=3001
