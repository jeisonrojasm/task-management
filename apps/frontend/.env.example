# Frontend env (Vite). OPTIONAL — the app works without this file.
#
# `VITE_API_URL` overrides the backend base URL used by the Axios client
# (apps/frontend/src/shared/lib/axios.ts). When unset it defaults to
# http://localhost:3000, which is correct for both `docker compose up` and local dev.
#
# Only create a real `.env` if you need to point the frontend at a different backend:
#   cp apps/frontend/.env.example apps/frontend/.env

# VITE_API_URL=http://localhost:3000
