# Database
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=taskmanager
DATABASE_URL=postgresql://appuser:changeme@postgres:5432/taskmanager

# Backend
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GLOBAL=1000
RATE_LIMIT_MAX_WRITE=100

# AI Provider (optional — if not set, MockAIProvider is used by default)
# OPENAI_API_KEY=sk-...

# JWT
# JWT_SECRET=
# JWT_EXPIRY=15m
